# Add this to your .env.local file
# You can get these values from your Supabase dashboard

# Public Supabase URL (already exists)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url

# Public anon key (already exists) 
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service role key (needed for user management API)
# ⚠️ IMPORTANT: This is a SECRET key - never expose in client-side code
# Get this from Supabase Dashboard > Settings > API > Service Role Key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# CCB (Church Community Builder) API Configuration
# Get these from your CCB admin panel under API settings
CCB_SUBDOMAIN=your_church_subdomain
CCB_API_USERNAME=your_ccb_api_username
CCB_API_PASSWORD=your_ccb_api_password

# Email Configuration (for daily summary emails)
# Sign up for a free account at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxx
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=Radius CRM
DAILY_SUMMARY_EMAIL=your-email@example.com

# Security for scheduled functions
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=your_random_secret_here

# AI Meeting Summary
# Primary: Google Gemini 2.0 Flash (free tier: 15 req/min)
# Get a free API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Fallback: Groq (free tier: 30 req/min, uses Llama 3.3 70B)
# Get a free API key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Production domain for auth redirects
# IMPORTANT: Use your custom domain, not the Netlify preview URLs
# Example: https://myradiuscrm.com (no trailing slash)
NEXT_PUBLIC_APP_URL=https://myradiuscrm.com

# Web Push (PWA push notifications)
# Generate a P-256 VAPID pair and keep the private key server-only.
# Subject should be a mailto: address or your production origin.
NEXT_PUBLIC_WEB_PUSH_VAPID_PUBLIC_KEY=your_vapid_public_key
WEB_PUSH_VAPID_PRIVATE_KEY=your_vapid_private_key
WEB_PUSH_VAPID_SUBJECT=mailto:admin@yourdomain.com

# --- Circle Leader Toolkit (leader-facing portal) ---

# Secret for signing leader magic-link / session tokens (min 32 chars).
# ⚠️ MUST be byte-identical on the main RADIUS site and the dedicated toolkit
# site — reminder links are signed on main but verified on the toolkit site.
# Generate with: openssl rand -base64 48
LEADER_SESSION_SECRET=your_leader_session_secret_here

# Dedicated hostname for the toolkit (e.g. circlestoolkit.netlify.app). When set,
# middleware serves the toolkit at this host's root and leader-facing links
# (magic-link emails, push deep links) point here. Leave empty for local dev
# (toolkit stays at /circle-leader-toolkit). Set on BOTH Netlify sites in prod.
LEADER_TOOLKIT_HOST=

# Set to "true" ONLY on the dedicated toolkit Netlify site so scheduled (cron)
# functions run on the main RADIUS site alone (no duplicate reminders/syncs).
# Leave empty on the main site / local dev. (The toolkit site also auto-disables
# cron whenever its own URL matches LEADER_TOOLKIT_HOST.)
DISABLE_SCHEDULED_FUNCTIONS=

# Optional: separate Resend account + sender for leader-facing toolkit emails.
# Each falls back to RESEND_API_KEY / EMAIL_FROM / EMAIL_FROM_NAME if unset.
LEADER_TOOLKIT_RESEND_API_KEY=
LEADER_TOOLKIT_EMAIL_FROM=
LEADER_TOOLKIT_EMAIL_FROM_NAME=
