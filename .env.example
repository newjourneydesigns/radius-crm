# AI providers — optional. Without keys the app falls back to a built-in
# command parser and game registry, so everything still works offline.

# Google Gemini 2.0 Flash (primary interpreter + vision)
GEMINI_API_KEY=

# Groq Llama 3.3 70B (fallback interpreter)
GROQ_API_KEY=

# Supabase — optional; powers accounts + shared live tables.
# Create a project, run supabase/schema.sql in its SQL editor, then set:
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
